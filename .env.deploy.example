# ══════════════════════════════════════════════════════════════════════════════
# MCP Forge — portable deploy env. Copy to .env (or paste into your platform's
# dashboard) and fill in. Works the same on Docker Compose, Render, Fly, Railway,
# or a bare VM. The ONLY things that differ between platforms are the URLs in the
# first block — change those and everything else just works.
#
#   cp .env.deploy.example .env
# ══════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────────
# 1. INTER-SERVICE URLs  ← the only knobs that change per platform
# ──────────────────────────────────────────────────────────────────────────────
# Four services talk to each other: web + generator + scraper + monitor.
# Point each variable at wherever that service actually lives. Internal/private
# networking is preferred (free, fast, no public exposure) but a public https URL
# works identically — just paste it in.
#
# Reachability cheat-sheet (host:port to use for each platform's PRIVATE network):
#   Docker Compose : http://scraper:8000        http://generator:8081/enqueue
#   Render         : http://scraper:10000       http://generator:10000/enqueue   (Render assigns $PORT=10000 to private services)
#   Fly.io         : http://scraper.internal:8000   http://generator.internal:8081/enqueue
#   Railway        : http://scraper.railway.internal:8000   http://generator.railway.internal:8081/enqueue
#   Bare VM/public : https://scraper.example.com   https://generator.example.com/enqueue

# Postgres + Redis (every service that needs state reads these).
DATABASE_URL=postgres://postgres:postgres@postgres:5432/mcp
REDIS_URL=redis://redis:6379

# generator → scraper  (HTML rendering microservice)
SCRAPER_URL=http://scraper:8000

# monitor → generator  (re-scrape enqueue endpoint; note the /enqueue path)
ENQUEUE_URL=http://generator:8081/enqueue

# Port a service binds. Most PaaS INJECT this automatically — leave it unset there.
# Only set it for local/Compose/VM runs. web defaults 3001, generator 8081, scraper 8000.
# PORT=

# ──────────────────────────────────────────────────────────────────────────────
# 2. LLM provider (pick one; OpenAI is the default)
# ──────────────────────────────────────────────────────────────────────────────
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4
# ANTHROPIC_API_KEY=sk-ant-...      # set LLM_PROVIDER=claude to use
# CLAUDE_MODEL=claude-sonnet-4-6
# GEMINI_API_KEY=AIza...            # set LLM_PROVIDER=gemini to use
# GEMINI_MODEL=gemini-3.1-pro-preview

# ──────────────────────────────────────────────────────────────────────────────
# 3. App config
# ──────────────────────────────────────────────────────────────────────────────
# Generated server bundles + scrape artifacts. Use a mounted volume in prod.
ARTIFACT_ROOT=/data/artifacts

# How often the monitor re-checks tracked servers.
POLL_INTERVAL=60s

# MongoDB Atlas (per-domain tool cache) — optional.
MONGODB_URI=
MONGODB_DATABASE=mcp_forge
MONGODB_COLLECTION=tools

# Solana on-chain registry — optional.
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_REGISTRY_KEYPAIR=

# ElevenLabs (voice in the browser extension) — optional.
ELEVENLABS_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# 4. Postgres bootstrap (only used by Docker Compose's bundled postgres)
# ──────────────────────────────────────────────────────────────────────────────
POSTGRES_DB=mcp
POSTGRES_PASSWORD=postgres
HTTP_PORT=8080
