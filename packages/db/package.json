{
  "name": "@mcp/db",
  "version": "0.0.0",
  "private": true,
  "description": "Postgres schema (Drizzle) + migrations. See docs/02-data-model.md.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": ["dist", "migrations"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate": "drizzle-kit generate",
    "apply": "node scripts/apply-migrations.mjs",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "dependencies": {
    "@mcp/types": "0.0.0",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.0"
  }
}
