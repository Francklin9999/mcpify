{
  "manifest_version": 3,
  "name": "MCP Forge: Page Chat",
  "version": "0.1.0",
  "description": "Chat about any page, and turn it into a runnable MCP server. Generated servers run locally; credentials never leave your browser.",
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "permissions": ["webRequest", "activeTab", "scripting", "sidePanel", "storage", "tabs", "downloads"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png" } },
  "side_panel": { "default_path": "sidepanel.html" },
  "options_page": "options.html"
}
