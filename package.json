{
  "name": "mcp-platform",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "packages/*",
    "apps/*",
    "services/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "sync:extension-config": "node scripts/sync-extension-config.mjs",
    "build": "npm run build --workspaces --if-present",
    "build:phase0": "npm run build --workspace=@mcp/types && npm run build --workspace=@mcp/db",
    "pretest": "npm run build:phase0",
    "test": "npm run test --workspaces --if-present",
    "vercel-build": "npm run build --workspace=@mcp/web",
    "deploy:build": "docker compose -f infra/compose.prod.yml build",
    "deploy:up": "docker compose -f infra/compose.prod.yml up -d --build",
    "deploy:down": "docker compose -f infra/compose.prod.yml down",
    "deploy:logs": "docker compose -f infra/compose.prod.yml logs -f load-balancer web generator scraper monitor",
    "deploy:ps": "docker compose -f infra/compose.prod.yml ps"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "esbuild": "^0.25.12",
    "postcss": "^8.5.15",
    "uuid": "^11.1.1"
  }
}
