{
  "name": "@mcp/generator",
  "version": "0.0.0",
  "private": true,
  "description": "Inference + codegen + self-healer. See docs/services/generator.md.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": { "types": "./dist/src/index.d.ts", "default": "./dist/src/index.js" },
    "./lean": { "types": "./dist/src/lean.d.ts", "default": "./dist/src/lean.js" },
    "./dist/src/*": "./dist/src/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "npm run build --workspace=@mcp/types && tsc -p tsconfig.json",
    "worker": "node dist/src/main.js",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.0",
    "@google/generative-ai": "^0.24.1",
    "@mcp/db": "0.0.0",
    "@mcp/types": "0.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "bullmq": "^5.77.6",
    "drizzle-orm": "^0.45.2",
    "openai": "^6.42.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
