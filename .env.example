# MCP Forge — copy this to .env and fill in your keys.
#   cp .env.example .env
# Run with: ./run.sh

# ── LLM provider ──────────────────────────────────────────────────────────────
# If LLM_PROVIDER is not set (or left as "openai"), the app uses OpenAI gpt-5.4.
# Set it to "claude" or "gemini" to switch providers — the others are ignored.
LLM_PROVIDER=openai

# OpenAI  (default — used when LLM_PROVIDER=openai or when LLM_PROVIDER is unset)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4

# Claude  (Anthropic — set LLM_PROVIDER=claude to activate)
ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-6

# Gemini  (Google — set LLM_PROVIDER=gemini to activate)
GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-3.1-pro-preview

# ── ElevenLabs (voice input + TTS in the browser extension) ───────────────────
ELEVENLABS_API_KEY=your-elevenlabs-key

# ── MongoDB Atlas (per-domain tool cache) ─────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxx.mongodb.net/?appName=Cluster0
# MONGODB_DATABASE=mcp_forge
# MONGODB_COLLECTION=tools

# ── Solana (on-chain server registry) ─────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_REGISTRY_KEYPAIR=/home/francklin99/.config/solana/id.json

# ── Infrastructure ─────────────────────────────────────────────────────────────
# These match docker-compose.yml defaults — only set if you run infra on different ports.
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/mcp
# REDIS_URL=redis://127.0.0.1:6379
# SCRAPER_URL=http://127.0.0.1:8000
# ARTIFACT_ROOT=/tmp/mcp-artifacts
