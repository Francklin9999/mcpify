# MCP Forge — environment configuration
# Copy to .env and fill in your values:
#   cp .env.example .env
# Then run ./run.sh — it loads .env and every service inherits it.

# ── LLM provider ──────────────────────────────────────────────────────────────
# Pick ONE provider. The matching API key must be set; all others are ignored.
# Without any key the system falls back to the keyless heuristic (real servers,
# lower quality — good for testing infra without spending API credits).
#
# LLM_PROVIDER=openai    (default)
# LLM_PROVIDER=claude
# LLM_PROVIDER=gemini

LLM_PROVIDER=openai

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Used when LLM_PROVIDER=openai (or as fallback if OPENAI_API_KEY is set
# and no other provider is active).
OPENAI_API_KEY=sk-your-key-here
# Model for tool inference, self-heal, and the assist chat.
# gpt-5.4 is the default (stronger structured output). Use gpt-4o for lower cost.
OPENAI_MODEL=gpt-4o
# Optional: reasoning effort for gpt-5.x models (none|minimal|low|medium|high|xhigh).
# OPENAI_REASONING=low

# ── Claude (Anthropic) ────────────────────────────────────────────────────────
# Used when LLM_PROVIDER=claude. Prompt caching is enabled automatically.
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Default: claude-sonnet-4-6. Other options: claude-opus-4-8, claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-sonnet-4-6

# ── Gemini (Google) ───────────────────────────────────────────────────────────
# Used when LLM_PROVIDER=gemini.
GEMINI_API_KEY=AIza-your-key-here
# Default: gemini-3.1-pro-preview (frontier). Other options: gemini-2.5-pro, gemini-2.5-flash
GEMINI_MODEL=gemini-3.1-pro-preview

# ── Agent (side-panel browsing agent) override ────────────────────────────────
# Override the model for the in-browser agent loop only (separate from inference).
# Useful if you want fast inference (e.g. gpt-4o) but a smarter agent (gpt-5.4).
# Leave unset to use the same model as the active provider above.
# AGENT_MODEL=gpt-5.4
# AGENT_REASONING=low

# ── Infra ─────────────────────────────────────────────────────────────────────
# These match the defaults in infra/docker-compose.yml. Only override if you
# run the services on non-default ports or a remote host.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mcp
REDIS_URL=redis://127.0.0.1:6379
SCRAPER_URL=http://127.0.0.1:8000
ARTIFACT_ROOT=/tmp/mcp-artifacts

# ── Web / extension ───────────────────────────────────────────────────────────
MCP_WEB_PROTOCOL=http
MCP_WEB_HOST=localhost
WEB_PORT=3001
MCP_API_BASE=http://localhost:3001
# Extension API base (set by sync:extension-config script from MCP_API_BASE).
# PLASMO_PUBLIC_API=http://localhost:3001

# Capture bundles directory (for community contributions).
# CAPTURE_BUNDLE_DIR=/tmp/mcp-capture-bundles

# ── Browser / Playwright (generated server runtime) ───────────────────────────
# Set in the environment where users RUN their generated servers, not the worker.
# MCP_BROWSER_HEADLESS=0          # set to "0" for headed (visible) browser
# MCP_BROWSER_CHANNEL=chrome      # e.g. "chrome", "firefox"
# MCP_BROWSER_PATH=/usr/bin/chromium  # custom browser executable
# MCP_STORAGE_STATE=/path/to/state.json  # Playwright session (cookies/auth)

# ── Solana (on-chain server registry) ─────────────────────────────────────────
# Optional. Without these the on-chain registry is silently skipped.
# SOLANA_RPC_URL=https://api.devnet.solana.com   # or http://localhost:8899 for local
# SOLANA_REGISTRY_KEYPAIR=/path/to/keypair.json  # JSON byte-array or file path
