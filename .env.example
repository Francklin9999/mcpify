# urlmcp — all configuration is optional. The default (host-as-brain) needs no keys and no services.
# Set any of these in your MCP client's `env` block, or export them before running the server directly.

# ── Server-side inference for forge_generate (optional) ───────────────────────
# Default is "host": your agent does the inference. Set a provider to have the server do it instead.
# Accepts a name or LiteLLM-style "provider/model", e.g. groq/llama-3.3-70b-versatile.
# FORGE_INFERENCE=host
# FORGE_MODEL=

# Provider keys — only the one matching FORGE_INFERENCE is used.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...
# GROQ_API_KEY=gsk_...

# Any OpenAI-compatible endpoint (gateway/proxy/new provider):
# FORGE_INFERENCE=openai-compatible
# FORGE_OPENAI_BASE_URL=https://my-gateway/v1
# FORGE_API_KEY=

# Bring-your-own inference logic (POST scraped page → return tool JSON):
# FORGE_INFERENCE=http
# FORGE_INFERENCE_URL=https://my-host/infer

# ── Scraping / browser (optional) ─────────────────────────────────────────────
# URLMCP_HOME=~/.urlmcp                # where generated servers are written
# FORGE_BROWSER=1                       # in-process stealth browser for dynamic sites (0 = static only)
# MCP_BROWSER_CHANNEL=chrome            # drive your real Chrome for stronger stealth
# FORGE_BROWSER_PROFILE=clone           # reuse your signed-in Chrome profile (clone|real|<path>) so capture is already logged in
# MCP_BROWSER_DRIVER=patchright         # stealth-patched Playwright drop-in (install it yourself)
# SCRAPER_URL=                          # use a remote Playwright scraper service instead of in-process
#
# ── Logged-in sites: capture in your REAL signed-in browser (YouTube, Gmail, ...) ──
# (By default, when real Chrome + a display exist, urlmcp auto-opens a signed-in clone with a debug port.)
# FORGE_USE_REAL_BROWSER=0              # opt OUT of the auto real-browser default; always use the managed browser
# FORGE_BROWSER_CDP=9222                 # attach to a Chrome you started with --remote-debugging-port=9222 (your live session)
# FORGE_BROWSER_CDP=launch              # ...or let urlmcp open your real Chrome with a debug port (pair with FORGE_BROWSER_PROFILE=clone)
# FORGE_BROWSER_BACKEND=extension       # ...or drive your everyday Chrome via the extension: `npx urlmcp install-extension` first
#
# ── Site-aware crawl: start at the base domain, explore a few pages, include the given path ──
# FORGE_CRAWL=0                          # disable crawl (single-page capture)
# FORGE_CRAWL_MAX_PAGES=4               # total pages captured (root + given + explored)
# FORGE_CRAWL_BUDGET_MS=90000           # stop exploring after this much wall-clock
