# Copy this file to .env and fill in your key:
#   cp .env.example .env
# Then run ./run.sh — the script loads .env and every service inherits it.

# --- LLM (OpenAI) ----------------------------------------------------------
# Required for real inference. Without it the worker + web chat fall back to
# the keyless heuristic (still produces real servers, just lower quality).
OPENAI_API_KEY=sk-your-key-here
# Optional — model used for tool inference, self-heal, and the assist chat.
OPENAI_MODEL=gpt-4o

# --- Infra (defaults match infra/docker-compose.yml; override only if needed) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mcp
REDIS_URL=redis://127.0.0.1:6379
SCRAPER_URL=http://127.0.0.1:8000
ARTIFACT_ROOT=/tmp/mcp-artifacts

# --- Web ------------------------------------------------------------------
# Defaults come from mcp.config.json. Override these only if you also want
# ./run.sh to sync the extension default to the same API base.
MCP_WEB_PROTOCOL=http
MCP_WEB_HOST=localhost
WEB_PORT=3001
MCP_API_BASE=http://localhost:3001
