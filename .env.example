# MCP Forge — copy this to .env and fill in your keys.
#   cp .env.example .env
# Run with: ./run.sh

# ── LLM provider ──────────────────────────────────────────────────────────────
# If LLM_PROVIDER is not set (or left as "openai"), the app uses OpenAI gpt-5.4.
# Set it to "claude" or "gemini" to switch providers — the others are ignored.
LLM_PROVIDER=openai

# OpenAI  (default — used when LLM_PROVIDER=openai or when LLM_PROVIDER is unset)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4

# Claude  (Anthropic — set LLM_PROVIDER=claude to activate)
ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-6

# Gemini  (Google — set LLM_PROVIDER=gemini to activate)
GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-3.1-pro-preview

# ── Server catalog (browsable directory of pre-generated servers) ─────────────
# Lives in Postgres now (the `catalog` table) - no separate database. Seed it with:
#   npm run seed:catalog   (requires DATABASE_URL + a built generator)

# ── Infrastructure ─────────────────────────────────────────────────────────────
# These match docker-compose.yml defaults — only set if you run infra on different ports.
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/mcp
# REDIS_URL=redis://127.0.0.1:6379
# SCRAPER_URL=http://127.0.0.1:8000
# ARTIFACT_ROOT=/tmp/mcp-artifacts
# The scraper refuses to fetch non-public/internal URLs (SSRF guard). Set to 1 ONLY if you intentionally
# scrape internal hosts you control (also needed if you point it at a localhost test server).
# SCRAPER_ALLOW_PRIVATE_HOSTS=1

# ── Docker deployment ─────────────────────────────────────────────────────────
# Used by infra/compose.prod.yml. The compose stack uses container-internal
# DATABASE_URL/REDIS_URL values even if your local .env has localhost values.
HTTP_PORT=8080
POSTGRES_DB=mcp
POSTGRES_PASSWORD=postgres
POLL_INTERVAL=60s
